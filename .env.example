# ── Next.js Frontend (.env.local) ────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# Sanity project details — get these from sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity webhook secret — any random string, set same value in Sanity webhook config
SANITY_WEBHOOK_SECRET=any-random-string-here
