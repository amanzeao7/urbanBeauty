# ── Payload CMS (.env) ───────────────────────────────────────────────────────
# Copy to .env in your payload directory and fill in values.

# MongoDB connection string — MongoDB Atlas free tier works great
DATABASE_URI=mongodb+srv://user:password@cluster.mongodb.net/urban-beauty

# Strong random secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-a-long-random-string

# The public URL Payload is served from
PAYLOAD_URL=https://your-payload-host.railway.app

# Allow your Next.js frontend to call Payload
CORS_URLS=http://localhost:3000,https://www.urbanbeautysalon.co.uk

# Vercel deploy hook — paste the URL from:
# Vercel → Project → Settings → Git → Deploy Hooks → Create Hook (name: "Payload CMS", branch: main)
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/xxxxxxxxxxxxxxxx
